{
  "name": "stones",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:server": "cross-env PORT=3001 nodemon --ext js,ts,tsx,json,css server.js",
    "dev:client": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "prebuild": "node scripts/write-version.js && node scripts/copy-geojson.js",
    "build": "tsc -b && vite build",
    "deploy": "npm run build && gh-pages -d dist",
    "test": "vitest",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server.js"
  },
  "homepage": "./",
  "dependencies": {
    "express": "^4.19.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-window": "^1.8.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^5.0.0",
    "globals": "^17.5.0",
    "nodemon": "^3.1.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^1.6.1"
  }
}
